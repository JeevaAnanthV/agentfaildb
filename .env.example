# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
TASK_MODEL=llama3.1:8b
ANNOTATION_MODEL=llama3.1:8b
OLLAMA_NUM_CTX=8192

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentfaildb
POSTGRES_USER=agentfaildb
POSTGRES_PASSWORD=agentfaildb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Optional: Anthropic API (annotation pipeline upgrades to Claude if set)
# ANTHROPIC_API_KEY=sk-ant-...

# Benchmark settings
RUN_TIMEOUT_SECONDS=120
MAX_TOKENS_PER_RUN=10000
MAX_MESSAGES_PER_RUN=20
RESOURCE_EXHAUSTION_MULTIPLIER=3.0

# Annotation
ANNOTATION_PASSES=3
ANNOTATION_CONFIDENCE_THRESHOLD=0.5
